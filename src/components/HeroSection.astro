---
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-800 pt-20"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-20 left-10 h-72 w-72 rounded-full bg-gold-500 blur-3xl"></div>
    <div class="absolute right-10 bottom-20 h-96 w-96 rounded-full bg-gold-500 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-gold-500/30 bg-gold-500/10 px-4 py-2">
      <span class="h-2 w-2 rounded-full bg-gold-500"></span>
      <span class="text-sm font-medium text-gold-400">Cancún, Quintana Roo</span>
    </div>

    <!-- Headline -->
    <h1
      class="mb-6 text-4xl leading-tight font-extrabold tracking-tight text-white sm:text-5xl md:text-6xl"
      data-i18n="hero.headline"
    >
      Transformamos la Presencia Digital de tu Empresa
    </h1>

    <!-- Subheadline -->
    <p
      class="mx-auto mb-10 max-w-2xl text-lg text-white/70 sm:text-xl"
      data-i18n="hero.subheadline"
    >
      Somos expertos en desarrollo web y rediseño digital para empresas del Caribe Mexicano. Llevamos tu marca al siguiente nivel con soluciones modernas y profesionales.
    </p>

    <!-- CTA -->
    <a
      href="#contact"
      class="inline-flex items-center gap-2 rounded-lg bg-gold-500 px-8 py-4 text-lg font-semibold text-navy-900 shadow-lg shadow-gold-500/25 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/30"
    >
      <span data-i18n="hero.cta">Solicita tu Consulta Gratuita</span>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
