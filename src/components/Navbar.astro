---
import LanguageToggle from './LanguageToggle.tsx';
import MobileMenu from './MobileMenu.tsx';
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-navy-900/95 backdrop-blur-sm transition-all"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="#hero" class="flex items-center gap-2 text-xl font-bold text-white">
      <span class="text-gold-500">CDL</span>
      <span class="hidden sm:inline">Caribbean Digital Lab</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-8 md:flex">
      <a href="#services" class="nav-link text-sm font-medium text-white/80 transition-colors hover:text-gold-400">
        <span data-i18n="nav.services">Servicios</span>
      </a>
      <a href="#portfolio" class="nav-link text-sm font-medium text-white/80 transition-colors hover:text-gold-400">
        <span data-i18n="nav.portfolio">Portafolio</span>
      </a>
      <a href="#about" class="nav-link text-sm font-medium text-white/80 transition-colors hover:text-gold-400">
        <span data-i18n="nav.about">Nosotros</span>
      </a>
      <a href="#contact" class="nav-link text-sm font-medium text-white/80 transition-colors hover:text-gold-400">
        <span data-i18n="nav.contact">Contacto</span>
      </a>
      <LanguageToggle client:load />
    </div>

    <!-- Mobile: Toggle + Menu -->
    <div class="flex items-center gap-3 md:hidden">
      <LanguageToggle client:load />
      <MobileMenu client:load />
    </div>
  </div>
</nav>
