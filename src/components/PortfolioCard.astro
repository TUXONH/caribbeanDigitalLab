---
import type { PortfolioProject } from '../data/portfolio';

interface Props {
  project: PortfolioProject;
  delay?: number;
}

const { project, delay = 0 } = Astro.props;
---

<div
  class="animate-on-scroll group overflow-hidden rounded-xl border border-navy-900/5 bg-white shadow-sm transition-all hover:shadow-lg hover:shadow-gold-500/5"
  style={`transition-delay: ${delay}ms`}
>
  <!-- Image -->
  <div class="relative aspect-video overflow-hidden bg-navy-900/5">
    <img
      src={project.image}
      alt={project.name}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <!-- Industry Badge -->
    <span class="absolute top-4 left-4 rounded-full bg-gold-500 px-3 py-1 text-xs font-semibold text-navy-900">
      <span data-i18n-portfolio-industry={project.id}>{project.industry.es}</span>
    </span>
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="mb-2 text-lg font-bold text-navy-900">{project.name}</h3>
    <p
      class="mb-4 text-sm leading-relaxed text-slate-500"
      data-i18n-portfolio-desc={project.id}
    >
      {project.description.es}
    </p>
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-sm font-semibold text-gold-600 transition-colors hover:text-gold-500"
    >
      <span data-i18n="portfolio.visitSite">Visitar Sitio</span>
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
    </a>
  </div>
</div>
