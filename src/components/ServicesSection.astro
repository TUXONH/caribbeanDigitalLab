---
import ServiceCard from './ServiceCard.astro';

const icons = {
  webDev: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  redesign: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>`,
  branding: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>`,
  seo: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
};
---

<section id="services" class="bg-[#FAFAFA] py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2
        class="mb-4 text-3xl font-bold text-navy-900 sm:text-4xl"
        data-i18n="services.title"
      >
        Nuestros Servicios
      </h2>
      <p
        class="mx-auto max-w-2xl text-lg text-slate-500"
        data-i18n="services.subtitle"
      >
        Soluciones digitales integrales para impulsar tu negocio en el mercado local e internacional.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <ServiceCard
        icon={icons.webDev}
        titleKey="services.items.0.title"
        descriptionKey="services.items.0.description"
        titleDefault="Desarrollo Web"
        descriptionDefault="Sitios web a medida con tecnología de punta."
        delay={0}
      />
      <ServiceCard
        icon={icons.redesign}
        titleKey="services.items.1.title"
        descriptionKey="services.items.1.description"
        titleDefault="Rediseño Digital"
        descriptionDefault="Renovamos por completo la imagen digital de tu empresa."
        delay={100}
      />
      <ServiceCard
        icon={icons.branding}
        titleKey="services.items.2.title"
        descriptionKey="services.items.2.description"
        titleDefault="Branding & Identidad"
        descriptionDefault="Creamos una identidad visual que refleja la esencia de tu marca."
        delay={200}
      />
      <ServiceCard
        icon={icons.seo}
        titleKey="services.items.3.title"
        descriptionKey="services.items.3.description"
        titleDefault="SEO & Marketing Digital"
        descriptionDefault="Posicionamos tu negocio en los primeros resultados de búsqueda."
        delay={300}
      />
    </div>
  </div>
</section>
